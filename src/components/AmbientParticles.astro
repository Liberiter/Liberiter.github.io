---
// 전역 앰비언트 파티클 (v4) — 문서 좌표 앵커 캔버스.
// z-index: 배경(body::after, z-1) 위 · 콘텐츠(main, z2) 아래.
// 다크 = 별 44 + 반딧불이 12 / 라이트 = 황금 먼지 44 + 발광 12 (화면당, 양 테마 동등).
---

<canvas id="ambient-canvas" aria-hidden="true"></canvas>

<style>
  #ambient-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }
</style>

<script>
  import { initAmbientParticles } from '../scripts/ambient-particles';

  const canvas = document.getElementById('ambient-canvas') as HTMLCanvasElement | null;
  if (canvas) initAmbientParticles(canvas);
</script>
