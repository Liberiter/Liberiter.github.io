---
import "../styles/hero.css";
---

<section class="hero-portal" id="heroPortal">
  <!-- ambient sky 배경 -->
  <div class="hero-sky"></div>

  <!-- ============================================================
       DARK SCENE — The Hidden Grove
       달 + 전나무 숲의 액자 구도 + 먼 모닥불
       ============================================================ -->
  <svg
    class="hero-scene scene-dark"
    viewBox="0 0 1600 900"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <!-- 유기적 능선 필터 — 노이즈로 윤곽을 뒤틀어 "손으로 그린" 느낌을 만든다 -->
      <filter id="roughFarD" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.025" numOctaves="3" seed="11" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="24" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="2.6" />
      </filter>
      <filter id="roughMidD" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.009 0.028" numOctaves="3" seed="4" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="16" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="0.6" />
      </filter>
      <filter id="roughGroundD" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.006 0.02" numOctaves="2" seed="27" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="10" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="0.4" />
      </filter>

      <!-- 전나무 실루엣 (기준: 밑동 중앙 원점, 높이 120) -->
      <path
        id="fir"
        d="M0 -120 L -17 -82 L -9 -84 L -28 -48 L -16 -51 L -38 -12 L -5 -17 L -5 0 L 5 0 L 5 -17 L 38 -12 L 16 -51 L 28 -48 L 9 -84 L 17 -82 Z"
      />

      <radialGradient id="campFireGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#ff7a35" stop-opacity="0.7" />
        <stop offset="25%" stop-color="#e85020" stop-opacity="0.38" />
        <stop offset="60%" stop-color="#c04018" stop-opacity="0.12" />
        <stop offset="100%" stop-color="#c04018" stop-opacity="0" />
      </radialGradient>

      <radialGradient id="moonHalo" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#f5ecd4" stop-opacity="0.7" />
        <stop offset="25%" stop-color="#e4d8b8" stop-opacity="0.4" />
        <stop offset="55%" stop-color="#c8b890" stop-opacity="0.15" />
        <stop offset="100%" stop-color="#c8b890" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="moonBody" cx="45%" cy="42%" r="60%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
        <stop offset="35%" stop-color="#fbf6e4" stop-opacity="0.98" />
        <stop offset="80%" stop-color="#e8dab8" stop-opacity="0.95" />
        <stop offset="100%" stop-color="#c8b890" stop-opacity="0.85" />
      </radialGradient>
      <radialGradient id="moonInnerGlow" cx="50%" cy="45%" r="50%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.55" />
        <stop offset="60%" stop-color="#ffffff" stop-opacity="0" />
      </radialGradient>

      <!-- 달빛이 스민 능선 — 짙고 영롱한 에메랄드 (마루는 밝고, 아래로 깊어진다) -->
      <linearGradient id="ridgeFarD" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1f4a3c" />
        <stop offset="55%" stop-color="#122a21" />
        <stop offset="100%" stop-color="#0d1d17" />
      </linearGradient>
      <linearGradient id="ridgeMidD" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#17382d" />
        <stop offset="60%" stop-color="#0d211a" />
        <stop offset="100%" stop-color="#0a1712" />
      </linearGradient>
      <linearGradient id="ridgeGroundD" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#123024" />
        <stop offset="100%" stop-color="#071009" />
      </linearGradient>

      <linearGradient id="hazeDark" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0f1c17" stop-opacity="0" />
        <stop offset="50%" stop-color="#12211b" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#12211b" stop-opacity="0" />
      </linearGradient>

      <linearGradient id="fadeToBgDark" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#101915" stop-opacity="0" />
        <stop offset="45%" stop-color="#101915" stop-opacity="0.5" />
        <stop offset="100%" stop-color="#101915" stop-opacity="1" />
      </linearGradient>
    </defs>

    <!-- (1) 달 -->
    <circle cx="800" cy="235" r="280" fill="url(#moonHalo)" />
    <circle class="moon-core" cx="800" cy="235" r="65" fill="url(#moonBody)" />
    <circle cx="800" cy="235" r="65" fill="url(#moonInnerGlow)" />

    <!-- (2) 먼 능선 (blur) — 라이트 장면과 동일 지오메트리 -->
    <g filter="url(#roughFarD)">
      <path
        d="M 0 520 L 110 432 L 210 482 L 330 406 L 450 478 L 560 426 L 690 488 L 800 436 L 920 484 L 1040 420 L 1160 480 L 1290 440 L 1400 490 L 1500 456 L 1600 500 L 1600 640 L 0 640 Z"
        fill="url(#ridgeFarD)"
        opacity="0.8"
      />
    </g>

    <!-- (2b) 두 번째 능선 + 달빛 림라이트 — 라이트 장면과 동일 지오메트리 -->
    <g filter="url(#roughMidD)">
      <path
        d="M 0 560 L 140 470 L 265 522 L 405 444 L 545 516 L 665 470 L 805 528 L 950 458 L 1085 518 L 1225 472 L 1360 524 L 1480 490 L 1600 530 L 1600 700 L 0 700 Z"
        fill="url(#ridgeMidD)"
      />
      <path
        d="M 0 560 L 140 470 L 265 522 L 405 444 L 545 516 L 665 470 L 805 528 L 950 458 L 1085 518 L 1225 472 L 1360 524 L 1480 490 L 1600 530"
        fill="none"
        stroke="#9fd8c2"
        stroke-width="1.6"
        opacity="0.14"
      />
    </g>

    <!-- (3) 안개 띠 1 -->
    <rect x="0" y="440" width="1600" height="180" fill="url(#hazeDark)" />

    <!-- (4) 먼 전나무 띠 — 모닥불 자리(x 420~560)는 비워 시야를 연다 -->
    <g fill="#0d211a" opacity="0.9">
      <use href="#fir" transform="translate(60 612) scale(0.5)" />
      <use href="#fir" transform="translate(148 605) scale(0.58)" />
      <use href="#fir" transform="translate(236 614) scale(0.52)" />
      <use href="#fir" transform="translate(322 607) scale(0.6)" />
      <use href="#fir" transform="translate(610 610) scale(0.55)" />
      <use href="#fir" transform="translate(692 603) scale(0.62)" />
      <use href="#fir" transform="translate(1168 608) scale(0.55)" />
      <use href="#fir" transform="translate(1254 614) scale(0.6)" />
      <use href="#fir" transform="translate(1344 605) scale(0.52)" />
      <use href="#fir" transform="translate(1444 612) scale(0.58)" />
      <use href="#fir" transform="translate(1534 606) scale(0.5)" />
    </g>

    <!-- (5) 땅 — 라이트 장면과 동일 지오메트리 -->
    <path
      filter="url(#roughGroundD)"
      d="M 0 668 C 260 640 520 664 800 648 C 1000 636 1120 622 1300 634 C 1440 644 1540 638 1600 636 L 1600 820 L 0 820 Z"
      fill="url(#ridgeGroundD)"
      opacity="0.9"
    />

    <!-- (6) 안개 띠 2 -->
    <rect x="0" y="560" width="1600" height="180" fill="url(#hazeDark)" opacity="0.6" />

    <!-- (7) 가까운 전나무 -->
    <g fill="#08150f">
      <use href="#fir" transform="translate(112 758) scale(1.05)" />
      <use href="#fir" transform="translate(218 770) scale(0.9)" />
      <use href="#fir" transform="translate(1318 762) scale(1.0)" />
      <use href="#fir" transform="translate(1430 772) scale(0.92)" />
    </g>

    <!-- (8) 하단 fade -->
    <rect x="0" y="460" width="1600" height="440" fill="url(#fadeToBgDark)" />

    <!-- (9) 화면 가장자리의 거목 — 액자 구도 (fade 위에 그려 또렷하게) -->
    <g fill="#06100b">
      <use href="#fir" transform="translate(28 832) scale(1.9)" />
      <use href="#fir" transform="translate(1572 838) scale(2.05)" />
      <use href="#fir" transform="translate(1492 852) scale(1.35)" />
    </g>

    <!-- (10) 모닥불 — 왼쪽 중경, 불티가 떠오른다 -->
    <g class="fire-glow">
      <circle cx="480" cy="655" r="150" fill="url(#campFireGlow)" />
      <circle cx="480" cy="660" r="5" fill="#ffb060" opacity="0.95" />
      <circle cx="480" cy="660" r="2" fill="#fff4d0" />
    </g>
    <circle class="floating-rune" cx="472" cy="623" r="1.6" fill="#f0c060" />
    <circle class="floating-rune" cx="490" cy="605" r="1.2" fill="#f0c060" style="animation-delay: -1.6s" />
    <circle class="floating-rune" cx="481" cy="587" r="1" fill="#e8a850" style="animation-delay: -2.9s" />
    <!-- 불가의 흔적 — 낮은 그림자와 돌 두엇 -->
    <ellipse cx="480" cy="676" rx="18" ry="2.5" fill="#020504" opacity="0.45" />
    <circle cx="462" cy="673" r="2" fill="#020504" opacity="0.6" />
    <circle cx="498" cy="674" r="1.6" fill="#020504" opacity="0.55" />
  </svg>

  <!-- ============================================================
       LIGHT SCENE — The Road Begins
       새벽 산맥 + 굽이치는 길 + 이정표 + 새떼
       ============================================================ -->
  <svg
    class="hero-scene scene-light"
    viewBox="0 0 1600 900"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <filter id="roughFarL" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.025" numOctaves="3" seed="17" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="20" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="2.3" />
      </filter>
      <filter id="roughMidL" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.009 0.028" numOctaves="3" seed="8" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="14" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="0.5" />
      </filter>
      <filter id="roughGroundL" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.006 0.02" numOctaves="2" seed="33" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="9" xChannelSelector="R" yChannelSelector="G" />
        <feGaussianBlur stdDeviation="0.4" />
      </filter>

      <radialGradient id="sunGlowSoft" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fff3d6" stop-opacity="0.85" />
        <stop offset="25%" stop-color="#f5d098" stop-opacity="0.55" />
        <stop offset="55%" stop-color="#e8a870" stop-opacity="0.22" />
        <stop offset="100%" stop-color="#e8a870" stop-opacity="0" />
      </radialGradient>

      <linearGradient id="farMountL" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#d8b898" stop-opacity="0.5" />
        <stop offset="100%" stop-color="#a89080" stop-opacity="0.55" />
      </linearGradient>
      <linearGradient id="midMountL" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#f0c898" stop-opacity="0.55" />
        <stop offset="15%" stop-color="#a88878" stop-opacity="0.7" />
        <stop offset="100%" stop-color="#7a5f50" stop-opacity="0.85" />
      </linearGradient>
      <linearGradient id="nearHillL" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#8c7258" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#5a4838" stop-opacity="0.95" />
      </linearGradient>

      <linearGradient id="hazeLight" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#f0dcc0" stop-opacity="0" />
        <stop offset="50%" stop-color="#f0dcc0" stop-opacity="0.5" />
        <stop offset="100%" stop-color="#f0dcc0" stop-opacity="0" />
      </linearGradient>

      <linearGradient id="fadeToBgLight" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#faf5e9" stop-opacity="0" />
        <stop offset="40%" stop-color="#faf5e9" stop-opacity="0.5" />
        <stop offset="75%" stop-color="#faf5e9" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#faf5e9" stop-opacity="1" />
      </linearGradient>
    </defs>

    <!-- (1) 태양 halo -->
    <circle cx="800" cy="235" r="280" fill="url(#sunGlowSoft)" />
    <circle class="sun-core" cx="800" cy="235" r="65" fill="#fff5dc" opacity="0.85" />

    <!-- (2) 먼 산맥 — 또렷한 능선 (blur로 대기감) -->
    <g filter="url(#roughFarL)">
      <path
        d="M 0 520 L 110 432 L 210 482 L 330 406 L 450 478 L 560 426 L 690 488 L 800 436 L 920 484 L 1040 420 L 1160 480 L 1290 440 L 1400 490 L 1500 456 L 1600 500 L 1600 640 L 0 640 Z"
        fill="url(#farMountL)"
      />
    </g>

    <!-- (3) 안개 띠 -->
    <rect x="0" y="440" width="1600" height="160" fill="url(#hazeLight)" />

    <!-- (4) 중간 산맥 + rim light -->
    <g filter="url(#roughMidL)">
      <path
        d="M 0 560 L 140 470 L 265 522 L 405 444 L 545 516 L 665 470 L 805 528 L 950 458 L 1085 518 L 1225 472 L 1360 524 L 1480 490 L 1600 530 L 1600 700 L 0 700 Z"
        fill="url(#midMountL)"
      />
      <path
        d="M 0 560 L 140 470 L 265 522 L 405 444 L 545 516 L 665 470 L 805 528 L 950 458 L 1085 518 L 1225 472 L 1360 524 L 1480 490 L 1600 530"
        fill="none"
        stroke="#fff2d4"
        stroke-width="1.8"
        opacity="0.45"
      />
    </g>

    <!-- (6) 가까운 언덕 -->
    <path
      filter="url(#roughGroundL)"
      d="M 0 668 C 260 640 520 664 800 648 C 1000 636 1120 622 1300 634 C 1440 644 1540 638 1600 636 L 1600 820 L 0 820 Z"
      fill="url(#nearHillL)"
    />

    <!-- (7) 굽이치는 길 — 넓게 시작해 S자로 휘며 이정표 앞을 지난다 -->
    <path
      d="M 620 900 C 608 852 613 822 625 800 C 652 750 820 738 912 721 C 982 707 1040 676 1070 650 L 1086 653 C 1054 682 1006 703 985 722 C 895 740 792 762 776 801 C 760 846 812 876 880 900 Z"
      fill="#ead9b8"
      opacity="0.55"
    />

    <!-- (8) 이정표 — 길가에 서 있다 -->
    <g transform="translate(1120 620)">
      <ellipse cx="0" cy="10" rx="26" ry="4" fill="#3a2818" opacity="0.75" />
      <rect x="-3" y="-128" width="6" height="138" fill="#4a3525" />
      <polygon points="-22,-116 22,-116 30,-106 22,-96 -22,-96" fill="#4a3525" />
      <polygon points="-30,-88 -22,-98 22,-98 22,-78 -22,-78" fill="#4a3525" />
      <polygon points="-22,-70 22,-70 30,-60 22,-50 -22,-50" fill="#4a3525" />
      <path d="M -5 -128 L 5 -128 L 4 -134 L -4 -134 Z" fill="#5a4530" />
      <!-- 풀섶 -->
      <g fill="none" stroke="#5a4838" stroke-width="1.5" opacity="0.8">
        <path d="M -36 7 q -2 -8 -6 -11" />
        <path d="M -32 8 q 0 -9 -3 -13" />
        <path d="M 32 7 q 2 -8 6 -11" />
        <path d="M 36 8 q 1 -9 4 -12" />
      </g>
      <!-- 들꽃 -->
      <g class="flower-sway">
        <path d="M -44 6 q -1 -8 1 -13" fill="none" stroke="#5a4838" stroke-width="1.3" />
        <circle cx="-43" cy="-8" r="2.2" fill="#c46240" opacity="0.85" />
      </g>
      <g class="flower-sway" style="animation-delay: -1.8s">
        <path d="M 44 7 q 1 -8 -1 -13" fill="none" stroke="#5a4838" stroke-width="1.3" />
        <circle cx="43" cy="-7" r="2" fill="#b5674c" opacity="0.85" />
      </g>
    </g>

    <!-- (9) 하단 fade -->
    <rect x="0" y="460" width="1600" height="440" fill="url(#fadeToBgLight)" />
  </svg>

  <!-- 캔버스 파티클 -->
  <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>

  <!-- 콘텐츠 -->
  <div class="hero-content">
    <p class="hero-welcome">Welcome, Traveler.</p>
    <h1 class="hero-title">The Wanderer's Crossroads</h1>
    <p class="hero-sub">
      길이 여럿으로 갈라지는 자리에 오신 것을 환영합니다.<br />
      수와 별, 말씀과 이야기, 여행자의 하루 — 열두 갈래 길이 이곳에서 교차합니다.
    </p>
  </div>

  <div class="scroll-cta">
    <span>Enter the Crossroads</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<script>
  import { initParticles } from "../scripts/particles";

  const canvas = document.getElementById("heroCanvas") as HTMLCanvasElement;
  if (canvas && !matchMedia("(prefers-reduced-motion: reduce)").matches) initParticles(canvas);
</script>
