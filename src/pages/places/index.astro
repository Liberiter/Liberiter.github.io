---
// 열두 장소 (v4) — 리다이렉트 스텁에서 진짜 페이지로 승격.
// 컴팩트 배너 + 12장소를 여정 순서대로 세로로 잇는 종주(縱走) 리스트.
// 문구: WORLDBOOK §2 · copy-deck §3. lore·입간판·칭호는 src/data/places.ts가 원본.
// 배너는 자체 scoped 구현 — 공용 PageBanner.astro가 준비되면 그대로 교체한다.
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Emblem from '../../components/Emblem.astro';
import { PLACES, rankFor, tintStyle } from '../../data/places';

// 장소별 기록 수 — 빌드 시 계산 (장소 상세와 동일한 로직)
const records = await getCollection('records', ({ data }) => !data.draft);
const countBy = new Map<string, number>();
for (const rec of records) countBy.set(rec.data.place, (countBy.get(rec.data.place) ?? 0) + 1);

const LOCI = ['Ⅰ', 'Ⅱ', 'Ⅲ', 'Ⅳ', 'Ⅴ', 'Ⅵ', 'Ⅶ', 'Ⅷ', 'Ⅸ', 'Ⅹ', 'Ⅺ', 'Ⅻ'];
const openCount = PLACES.filter((p) => (countBy.get(p.slug) ?? 0) > 0).length;

// 안개 땅은 문장색 대신 잿빛 — PlaceCard·장소 상세와 동일한 값
const fogTint = '--place-light:#6E6353;--place-dark:#9BB0A4';
---

<Base title="열두 장소" description="교차로의 열두 장소 안내 — 각 장소가 다루는 주제와 기록 목록으로 가는 길.">
  <!-- 컴팩트 배너 — 여명/숲 축소 그라데이션 (마크업은 단순하게, PageBanner 교체 대비) -->
  <section class="pl-banner" data-hd-range slot="hero">
    <div class="pb-in">
      <p class="pb-eyebrow">The Twelve Places</p>
      <h1 class="pb-title">열두 장소</h1>
      <p class="pb-flavor">각 길의 끝에는 문이 있다. 열린 문도, 아직 안개에 잠긴 문도.</p>
    </div>
  </section>

  <!-- 간기 스타일 통계 행 -->
  <p class="trek-stats" data-animate>
    열두 곳 중 <b>{openCount}</b>곳 개방<i class="dia" aria-hidden="true">✦</i>기록
    <b>{records.length}</b>편
  </p>

  <section class="home-section" aria-label="열두 장소의 종주">
    <ol class="trek">
      {
        PLACES.map((place, i) => {
          const count = countBy.get(place.slug) ?? 0;
          const fogged = count === 0;
          const rank = rankFor(place, count);
          return (
            <li
              class:list={['trek-stop', 'tinted', { flip: i % 2 === 1, fog: fogged }]}
              style={fogged ? fogTint : tintStyle(place)}
              title={fogged ? '첫 기록이 쓰이는 날, 안개가 걷힌다' : undefined}
              data-animate
            >
              <div class="ts-emblem" aria-hidden="true">
                <Emblem id={place.slug} size={64} />
                <span class="ts-locus">Locus {LOCI[i]}</span>
              </div>
              <div class="ts-body">
                <h2 class="ts-name">
                  {place.ko}
                  <span class="ts-en">{place.en}</span>
                </h2>
                <p class="ts-plaque">“{place.flavor}”</p>
                <p class="ts-lore">{place.lore}</p>
                {
                  fogged ? (
                    <p class="ts-meta ts-fog-note">
                      안개에 싸인 땅<i class="dia" aria-hidden="true">✦</i>첫 기록이 쓰이는 날,
                      안개가 걷힌다
                    </p>
                  ) : (
                    <p class="ts-meta">
                      <b>기록 {count}편</b>
                      {rank && (
                        <>
                          <i class="dia" aria-hidden="true">✦</i>
                          {rank}
                        </>
                      )}
                      <a class="ts-enter" href={`/places/${place.slug}/`}>
                        입장하기 <span aria-hidden="true">→</span>
                      </a>
                    </p>
                  )
                }
              </div>
            </li>
          );
        })
      }
    </ol>
  </section>
</Base>

<script>
  import { initScrollAnimations } from '../../scripts/scroll-animations';
  initScrollAnimations();
</script>

<style>
  /* ══════════════════════════════════════════════════════
     컴팩트 배너 — 라이트: 여명 하늘의 절제된 축소판
     (그라데이션 값은 히어로/ArchiveBanner 계열과 동일 계보)
     ══════════════════════════════════════════════════════ */
  .pl-banner {
    --banner-bg: linear-gradient(to bottom, #b8bfce 0%, #d4bcbe 34%, #e4c8a8 64%, #ecd8ba 82%, #faf5e9 100%);
    --banner-veil: radial-gradient(120% 80% at 50% 4%, rgba(255, 243, 214, 0.5), transparent 58%);
    --bn-eyebrow: #5a4020;
    --bn-eyebrow-sh: 0 1px 2px rgba(255, 245, 220, 0.6);
    --bn-title: #4a3010;
    --bn-title-sh: 0 1px 2px rgba(255, 245, 220, 0.6), 0 0 30px rgba(245, 212, 136, 0.35);
    --bn-sub: #3a2e20;
    --bn-sub-sh: 0 1px 2px rgba(255, 250, 230, 0.7);
    position: relative;
    overflow: hidden;
    margin-top: calc(-1 * var(--header-h));
    height: clamp(264px, 36vh, 340px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--banner-bg);
    transition: background 0.5s ease;
  }
  /* 다크 "칠흑의 숲" — global.css와 같은 3중 테마 선택자 패턴 */
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .pl-banner {
      --banner-bg: linear-gradient(180deg, #0b2438 0%, #0e2a30 36%, #14291c 64%, #1f2c1b 85%, #15211a 100%);
      --banner-veil: radial-gradient(90% 70% at 50% 100%, rgba(212, 170, 48, 0.1), transparent 62%);
      --bn-eyebrow: #d4aa30;
      --bn-eyebrow-sh: 0 0 18px rgba(0, 0, 0, 0.8), 0 0 8px rgba(0, 0, 0, 0.6);
      --bn-title: #d4aa30;
      --bn-title-sh: 0 0 20px rgba(0, 0, 0, 0.55), 0 0 40px rgba(212, 170, 48, 0.22), 0 0 80px rgba(212, 170, 48, 0.12);
      --bn-sub: #e5e0d1;
      --bn-sub-sh: 0 1px 3px rgba(0, 0, 0, 0.5);
    }
  }
  :global(:root[data-theme='dark']) .pl-banner {
    --banner-bg: linear-gradient(180deg, #0b2438 0%, #0e2a30 36%, #14291c 64%, #1f2c1b 85%, #15211a 100%);
    --banner-veil: radial-gradient(90% 70% at 50% 100%, rgba(212, 170, 48, 0.1), transparent 62%);
    --bn-eyebrow: #d4aa30;
    --bn-eyebrow-sh: 0 0 18px rgba(0, 0, 0, 0.8), 0 0 8px rgba(0, 0, 0, 0.6);
    --bn-title: #d4aa30;
    --bn-title-sh: 0 0 20px rgba(0, 0, 0, 0.55), 0 0 40px rgba(212, 170, 48, 0.22), 0 0 80px rgba(212, 170, 48, 0.12);
    --bn-sub: #e5e0d1;
    --bn-sub-sh: 0 1px 3px rgba(0, 0, 0, 0.5);
  }
  .pl-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: var(--banner-veil);
  }
  /* 하단 fade — body 배경과 이어붙임 */
  .pl-banner::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 34%;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, var(--bg) 100%);
  }
  .pb-in {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: calc(var(--header-h) * 0.6) 24px 0;
  }
  .pb-eyebrow {
    font-family: var(--display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5em;
    text-indent: 0.5em;
    text-transform: uppercase;
    color: var(--bn-eyebrow);
    text-shadow: var(--bn-eyebrow-sh);
    margin: 0 0 10px;
  }
  .pb-title {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(30px, 4.6vw, 44px);
    line-height: 1.25;
    letter-spacing: 0.14em;
    text-indent: 0.14em;
    color: var(--bn-title);
    text-shadow: var(--bn-title-sh);
    margin: 0;
  }
  .pb-flavor {
    font-family: var(--serif);
    font-size: clamp(13.5px, 1.8vw, 15.5px);
    color: var(--bn-sub);
    text-shadow: var(--bn-sub-sh);
    letter-spacing: 0.04em;
    margin: 12px 0 0;
  }

  /* ── 간기 통계 행 ── */
  .trek-stats {
    text-align: center;
    font-size: 12.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    margin: 28px 0 0;
  }
  .trek-stats b {
    font-weight: 600;
    color: var(--gold-text);
  }
  .trek-stats .dia,
  .ts-meta .dia {
    color: var(--gold);
    font-size: 9px;
    font-style: normal;
    margin: 0 10px;
  }

  /* ══════════════════════════════════════════════════════
     종주(縱走) — 한 장소씩 세로로 이어지는 리스트
     홀짝으로 문장을 좌우 번갈아 놓아 걷는 리듬을 만든다
     ══════════════════════════════════════════════════════ */
  .trek {
    list-style: none;
    max-width: 820px;
    margin: 0 auto;
    padding: 0;
  }
  .trek-stop {
    position: relative;
    display: grid;
    grid-template-columns: 128px 1fr;
    gap: clamp(20px, 4vw, 40px);
    align-items: start;
    padding: clamp(36px, 5.5vw, 52px) 8px;
  }
  .trek-stop.flip {
    grid-template-columns: 1fr 128px;
  }
  .trek-stop.flip .ts-emblem {
    order: 2;
  }
  .trek-stop.flip .ts-body {
    order: 1;
    text-align: right;
  }
  /* 장소 사이 — 가는 페이드 괘선 + 중앙 ✦ 오너먼트 */
  .trek-stop + .trek-stop {
    border-top: 1px solid transparent;
    border-image: linear-gradient(
        to right,
        transparent 6%,
        color-mix(in srgb, var(--gold) 40%, var(--line)) 50%,
        transparent 94%
      )
      1;
  }
  .trek-stop + .trek-stop::before {
    content: '✦';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 0 14px;
    background: var(--bg);
    color: var(--gold);
    font-size: 10px;
    line-height: 1;
    filter: var(--glow);
  }

  /* 좌(우): 문장 + Locus 번호 */
  .ts-emblem {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 4px;
    color: var(--place);
    filter: var(--glow);
  }
  .ts-emblem > :global(.emblem) {
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--place) 28%, transparent));
  }
  .ts-locus {
    font-family: var(--display);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-indent: 0.28em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--place) 55%, var(--muted));
  }

  /* 우(좌): 이름 + 입간판 + 여정 lore + 기록·칭호 */
  .ts-body {
    min-width: 0;
  }
  .ts-name {
    font-family: var(--serif);
    font-size: clamp(21px, 2.8vw, 26px);
    font-weight: 700;
    line-height: 1.35;
    color: var(--ink);
    margin: 0;
  }
  .ts-en {
    display: block;
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--place) 45%, var(--muted));
    margin-top: 5px;
  }
  /* 입간판 — 문장색 가는 괘선을 곁들인 인용 */
  .ts-plaque {
    font-family: var(--serif);
    font-size: 15px;
    font-style: italic;
    color: color-mix(in srgb, var(--place) 40%, var(--ink));
    border-left: 2px solid color-mix(in srgb, var(--place) 50%, transparent);
    padding-left: 14px;
    margin: 16px 0 0;
  }
  .trek-stop.flip .ts-plaque {
    border-left: 0;
    border-right: 2px solid color-mix(in srgb, var(--place) 50%, transparent);
    padding-left: 0;
    padding-right: 14px;
  }
  /* 여정 lore — 이 장소가 무엇을 다루는 공간인지 */
  .ts-lore {
    font-size: 15px;
    line-height: 1.9;
    color: var(--muted);
    max-width: 62ch;
    margin: 12px 0 0;
    text-wrap: pretty;
  }
  .trek-stop.flip .ts-lore {
    margin-left: auto;
  }
  .ts-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    font-family: var(--serif);
    font-size: 13.5px;
    color: var(--muted);
    margin: 14px 0 0;
  }
  .trek-stop.flip .ts-meta {
    justify-content: flex-end;
  }
  .ts-meta b {
    font-weight: 600;
    color: var(--gold-text);
  }
  .ts-enter {
    margin-left: 22px;
    font-size: 13px;
    color: var(--gold-text);
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .ts-enter:hover {
    text-decoration: none;
    color: var(--gold);
    border-bottom-color: var(--gold);
  }
  .trek-stop.flip .ts-enter {
    order: -1;
    margin-left: 0;
    margin-right: 22px;
  }

  /* ── 안개에 싸인 땅 — 잿빛 + 흐림, 입장 불가 (WORLDBOOK §5.1) ── */
  .trek-stop.fog {
    cursor: help;
  }
  .trek-stop.fog .ts-emblem,
  .trek-stop.fog .ts-name,
  .trek-stop.fog .ts-plaque,
  .trek-stop.fog .ts-lore {
    filter: saturate(0.2);
    opacity: 0.55;
  }
  .trek-stop.fog .ts-lore {
    filter: saturate(0.2) blur(0.6px);
  }
  .trek-stop.fog .ts-fog-note {
    font-style: italic;
    color: var(--muted);
  }

  /* ── 모바일: 문장을 위로, 본문은 왼쪽 정렬로 통일 ── */
  @media (max-width: 620px) {
    .trek-stop,
    .trek-stop.flip {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .trek-stop.flip .ts-emblem {
      order: 0;
    }
    .trek-stop.flip .ts-body {
      order: 1;
      text-align: left;
    }
    .trek-stop.flip .ts-plaque {
      border-right: 0;
      border-left: 2px solid color-mix(in srgb, var(--place) 50%, transparent);
      padding-right: 0;
      padding-left: 14px;
    }
    .trek-stop.flip .ts-lore {
      margin-left: 0;
    }
    .trek-stop.flip .ts-meta {
      justify-content: flex-start;
    }
    .trek-stop.flip .ts-enter {
      order: 0;
      margin-right: 0;
      margin-left: 22px;
    }
  }
</style>
