---
// 404 — 지도에 없는 땅 (Terra Incognita). 전면 한 화면 연출.
// 스펙: docs/mockups/404.html · 문구: docs/copy-deck.md §10 · 메타/aria는 평범하게 (WORLDBOOK §1.2).
import Base from '../layouts/Base.astro';
---

<Base title="페이지를 찾을 수 없습니다 (404)" description="요청한 페이지가 존재하지 않습니다.">
  <section class="lost-scene" data-hd-range>
    <!-- 안개 패치 — 비리디안 기운의 느린 표류 -->
    <div class="fog-patch fp-1" aria-hidden="true"></div>
    <div class="fog-patch fp-2" aria-hidden="true"></div>
    <div class="fog-patch fp-3" aria-hidden="true"></div>

    <div class="lost-in">
      <!-- 흐려지는 나침반 — 가장자리가 안개에 잠기고, 바늘은 길을 못 찾는다 -->
      <div class="compass-wrap" aria-hidden="true">
        <svg viewBox="0 0 200 200">
          <circle class="cp-line" cx="100" cy="100" r="92" stroke-width="1.5" opacity=".85"></circle>
          <circle class="cp-line" cx="100" cy="100" r="86" stroke-width=".75" opacity=".5"></circle>
          <circle class="cp-line" cx="100" cy="100" r="74" stroke-width="7" stroke-dasharray="1.4 6.35" opacity=".35"></circle>
          <circle class="cp-line" cx="100" cy="100" r="48" stroke-width=".75" opacity=".3"></circle>
          <text class="cp-card n" x="100" y="46" text-anchor="middle" dominant-baseline="middle">N</text>
          <text class="cp-card" x="154" y="100" text-anchor="middle" dominant-baseline="middle">E</text>
          <text class="cp-card" x="100" y="154" text-anchor="middle" dominant-baseline="middle">S</text>
          <text class="cp-card" x="46" y="100" text-anchor="middle" dominant-baseline="middle">W</text>
          <g class="needle">
            <path class="cp-needle-n" d="M100 30 L107 100 L100 110 L93 100 Z"></path>
            <path class="cp-needle-s" d="M100 170 L107 100 L100 90 L93 100 Z"></path>
          </g>
          <circle class="cp-pivot-ring" cx="100" cy="100" r="6" stroke-width="2"></circle>
          <circle class="cp-pivot-dot" cx="100" cy="100" r="2"></circle>
        </svg>
      </div>

      <p class="lt-eyebrow">Terra Incognita · 404</p>
      <h1 class="lt-title">지도에 없는 땅</h1>
      <div class="orn-line lt-orn" data-orn="tailpiece" aria-hidden="true"></div>
      <p class="lt-sub">
        이 길은 아직 그려지지 않았다.<br />
        안개 너머에는 아무것도 없거나, 아직 오지 않은 것이 있다.
      </p>

      <div class="lt-actions">
        <a class="btn btn-gold" href="/">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.5l1.8 7.7 7.7 1.8-7.7 1.8-1.8 7.7-1.8-7.7-7.7-1.8 7.7-1.8z"></path></svg>
          교차로로 돌아가기
        </a>
        <button class="btn btn-ghost" type="button" id="lost-search" aria-label="검색">
          <span class="dia" aria-hidden="true">✦</span>
          길잡이에게 묻기
        </button>
      </div>
    </div>
  </section>
</Base>

<script>
  // 길잡이에게 묻기 — 헤더의 검색 트리거와 같은 이벤트 (SearchModal이 수신)
  document.getElementById('lost-search')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-search'));
  });
</script>

<style>
  /* ══ 지도에 없는 땅 — 전면 한 화면 ══
     main.wrap 안에서 좌우 패딩만큼 블리드 (100vw 트릭은 가로 스크롤 위험이 있어 피한다) */
  .lost-scene {
    position: relative;
    overflow: hidden;
    margin: calc(-1 * var(--header-h)) calc(-1 * clamp(20px, 4vw, 48px)) 0;
    min-height: max(420px, calc(100dvh - 230px)); /* 푸터가 첫 화면 하단에 걸리도록 */
    display: flex;
    align-items: center;
    justify-content: center;
    --fog-strength: 14%; /* 안개 패치 농도 (라이트: 옅게) */
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .lost-scene {
      --fog-strength: 20%; /* 다크: 인광처럼 */
    }
  }
  :global(:root[data-theme='dark']) .lost-scene {
    --fog-strength: 20%;
  }

  /* 안개 패치 — blur 덩어리가 아주 느리게 표류 */
  .fog-patch {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--viridian) var(--fog-strength), transparent),
      transparent 74%
    );
    filter: blur(38px);
  }
  .fp-1 {
    width: 560px;
    height: 400px;
    top: 4%;
    left: -10%;
  }
  .fp-2 {
    width: 640px;
    height: 460px;
    top: 34%;
    right: -14%;
  }
  .fp-3 {
    width: 520px;
    height: 360px;
    bottom: -8%;
    left: 20%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .fog-patch {
      animation: fog-drift 56s ease-in-out infinite alternate;
    }
    .fp-2 {
      animation-duration: 64s;
      animation-delay: -22s;
    }
    .fp-3 {
      animation-duration: 48s;
      animation-delay: -37s;
    }
    @keyframes fog-drift {
      from {
        transform: translate3d(0, 0, 0) scale(1);
      }
      to {
        transform: translate3d(72px, -44px, 0) scale(1.09);
      }
    }
  }

  .lost-in {
    position: relative;
    z-index: 2; /* 전역 파티클 캔버스(z1) 위 */
    text-align: center;
    max-width: 560px;
    padding: calc(var(--header-h) + 20px) 24px 36px;
  }

  /* 흔들리는 나침반 — 안개 마스크 + sway */
  .compass-wrap {
    width: clamp(150px, 24vw, 190px);
    margin: 0 auto 28px;
    color: var(--muted);
    filter: var(--glow);
    -webkit-mask-image: radial-gradient(circle at 50% 50%, #000 52%, transparent 88%);
    mask-image: radial-gradient(circle at 50% 50%, #000 52%, transparent 88%);
    opacity: 0;
    animation: rise 1.2s ease 0.15s forwards;
  }
  .compass-wrap svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .cp-line {
    stroke: var(--muted);
    fill: none;
  }
  .cp-card {
    font-family: var(--display);
    font-size: 14px;
    font-weight: 600;
    fill: var(--muted);
    letter-spacing: 0.05em;
  }
  .cp-card.n {
    fill: var(--gold-text);
  }
  .cp-needle-n {
    fill: var(--gold);
  }
  .cp-needle-s {
    fill: var(--viridian);
    opacity: 0.8;
  }
  .cp-pivot-ring {
    fill: var(--bg);
    stroke: var(--gold);
  }
  .cp-pivot-dot {
    fill: var(--gold);
  }
  .needle {
    transform-box: view-box;
    transform-origin: 50% 50%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .compass-wrap {
      animation: rise 1.2s ease 0.15s forwards, compass-breathe 9s ease-in-out 1.5s infinite;
    }
    .needle {
      animation: needle-sway 8s ease-in-out infinite;
    }
    @keyframes needle-sway {
      0% {
        transform: rotate(-13deg);
      }
      34% {
        transform: rotate(9deg);
      }
      56% {
        transform: rotate(2deg);
      }
      76% {
        transform: rotate(7deg);
      }
      100% {
        transform: rotate(-13deg);
      }
    }
    @keyframes compass-breathe {
      0%,
      100% {
        opacity: 1;
      }
      50% {
        opacity: 0.68;
      }
    }
  }

  .lt-eyebrow {
    font-family: var(--display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-indent: 0.42em;
    text-transform: uppercase;
    color: var(--gold-text);
    margin: 0 0 12px;
    opacity: 0;
    animation: rise 1s ease 0.4s forwards;
  }
  .lt-title {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(30px, 5.4vw, 44px);
    line-height: 1.3;
    letter-spacing: 0.05em;
    color: var(--ink);
    margin: 0;
    opacity: 0;
    animation: rise 1.1s cubic-bezier(0.2, 0.7, 0.2, 1) 0.55s forwards;
  }
  .lt-orn {
    margin-top: 16px;
    opacity: 0;
    animation: rise 1s ease 0.75s forwards;
  }
  .lt-orn :global(svg) {
    width: 150px;
  }
  .lt-sub {
    font-size: 15.5px;
    line-height: 2;
    color: var(--muted);
    max-width: 430px;
    margin: 16px auto 0;
    text-wrap: pretty;
    opacity: 0;
    animation: rise 1s ease 0.9s forwards;
  }
  .lt-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 32px;
    opacity: 0;
    animation: rise 1s ease 1.1s forwards;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 700;
    padding: 11px 24px;
    border: 0;
    cursor: pointer;
    transition: color 0.25s, background-color 0.25s, border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .btn:hover {
    text-decoration: none;
  }
  .btn svg {
    width: 15px;
    height: 15px;
    flex: none;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .btn .dia {
    font-size: 9px;
    font-style: normal;
  }
  .btn-gold {
    background: var(--gold-text);
    color: var(--bg);
  }
  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px -8px color-mix(in srgb, var(--gold) 60%, transparent);
  }
  .btn-ghost {
    background: transparent;
    border: 1px solid var(--card-border);
    color: var(--muted);
  }
  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(26px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 모션 감소 존중 — 즉시 표시, 나침반·안개 정지 */
  @media (prefers-reduced-motion: reduce) {
    .compass-wrap,
    .lt-eyebrow,
    .lt-title,
    .lt-orn,
    .lt-sub,
    .lt-actions {
      animation: none;
      opacity: 1;
    }
    .btn {
      transition: none;
    }
  }
</style>
