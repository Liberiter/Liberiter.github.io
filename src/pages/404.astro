---
import Base from '../layouts/Base.astro';
import Emblem from '../components/Emblem.astro';
---

<Base title="지도에 없는 땅" description="페이지를 찾을 수 없습니다.">
  <section class="place-banner">
    <Emblem id="wanderers-journal" size={56} class="emblem" />
    <h1>지도에 없는 땅</h1>
    <p class="flavor">이 길은 아직 그려지지 않았다. 나침반이 흔들리고 있다.</p>
  </section>
  <div class="orn">✦</div>
  <p style="text-align:center">
    <a href="/">← 교차로로 돌아가기</a>
  </p>
</Base>
