---
// 표식(태그)별 기록 v4 — 서고와 같은 서지 템플릿, 배너 문구만 다르다.
// 문구는 docs/copy-deck.md §5 (표식 페이지 배너). 필터 칩 없이 서지 리스트만.
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageBanner from '../../components/PageBanner.astro';
import RecordBibliography from '../../components/RecordBibliography.astro';

export async function getStaticPaths() {
  const records = await getCollection('records', ({ data }) => !data.draft);
  const tags = new Set(records.flatMap((rec) => rec.data.tags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      records: records
        .filter((rec) => rec.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}
const { tag } = Astro.params;
const { records } = Astro.props;
---

<Base title={`태그: ${tag}`} description={`'${tag}' 태그가 달린 글 ${records.length}편.`}>
  <PageBanner
    slot="hero"
    eyebrow="Marked Records"
    title={tag}
    flavor={`「${tag}」 표식이 매인 기록들`}
  />

  <p class="stats-line" data-animate>기록 <b>{records.length}</b>편</p>

  <RecordBibliography records={records} />

  <!-- 순환 링크 — 표식에서 서고(표식 구름)로 되돌아가는 길 -->
  <p class="all-marks" data-animate>
    <a href="/records/"><span class="dia" aria-hidden="true">✦</span> 서고의 모든 표식 보기</a>
  </p>
</Base>

<style>
  .all-marks {
    text-align: center;
    margin: 34px 0 0;
  }
  .all-marks a {
    font-family: var(--serif);
    font-size: 13.5px;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .all-marks a:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
    text-decoration: none;
  }
  .all-marks .dia {
    color: var(--gold);
    font-size: 9px;
  }

  .stats-line {
    text-align: center;
    font-size: 12.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    margin: 28px 0 26px;
  }
  .stats-line b {
    font-weight: 600;
    color: var(--gold-text);
  }
</style>

<script>
  import { initScrollAnimations } from '../../scripts/scroll-animations';
  initScrollAnimations();
</script>
