---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RecordCard from '../../components/RecordCard.astro';

export async function getStaticPaths() {
  const records = await getCollection('records', ({ data }) => !data.draft);
  const tags = new Set(records.flatMap((rec) => rec.data.tags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      records: records
        .filter((rec) => rec.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}
const { tag } = Astro.params;
const { records } = Astro.props;
---

<Base title={`표식: ${tag}`} description={`${tag} 태그가 달린 기록 ${records.length}편.`}>
  <section class="place-banner">
    <div class="eyebrow">여정의 표식</div>
    <h1>#{tag}</h1>
    <p class="flavor">이 표식이 달린 기록 {records.length}편</p>
  </section>
  <div class="orn">✦</div>
  <div class="record-list">
    {records.map((rec) => <RecordCard rec={rec} />)}
  </div>
</Base>
