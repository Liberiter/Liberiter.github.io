---
// 여행자의 쉼터 (About) v4 — "여관(Inn)" 컨셉.
// 구성은 docs/mockups/rest.html, 문구는 docs/copy-deck.md §7.
// 이 페이지만 화롯불 온기 반 톤 ↑ (scoped 토큰 오버라이드 — global.css는 건드리지 않는다).
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Emblem from '../components/Emblem.astro';
import PageBanner from '../components/PageBanner.astro';
import { PLACES, rankFor, tintStyle } from '../data/places';

// 칭호의 방 — 장소별 발행 기록 수로 칭호를 빌드 시 계산 (WORLDBOOK §2.3, 수동 관리 금지)
const records = await getCollection('records', ({ data }) => !data.draft);
const countBy = new Map<string, number>();
for (const rec of records) countBy.set(rec.data.place, (countBy.get(rec.data.place) ?? 0) + 1);

const openCount = PLACES.filter((p) => (countBy.get(p.slug) ?? 0) > 0).length;
const KO_COUNT = ['', '한', '두', '세', '네', '다섯', '여섯', '일곱', '여덟', '아홉', '열', '열한', '열두'];

// 이 교차로에 대하여 — 취지 (copy-deck §7)
const CREDO = [
  { lead: '길 위에서 배운 것은 길 위에 남긴다', rest: '기록은 미래의 나에게 보내는 전서구다.' },
  { lead: '주제마다 건물을 세웠다', rest: '역사에서 수학까지, 신앙에서 소설까지. 관심사가 여러 갈래라 교차로가 되었다.' },
  { lead: '안개는 예고편이다', rest: '아직 기록이 없는 장소는 안개에 잠겨 있다. 첫 기록이 쓰이는 날, 안개가 걷힌다.' },
  { lead: '완성되지 않아도 좋다', rest: '세 줄의 일지도 당당하게 발행한다. 이 교차로의 적은 완벽주의다.' },
];

// ── 방랑자의 인장 — 룬 링 (빌드 타임 생성, 런타임 비용 0) ──
// 엘더 푸타르크풍 모노라인 룬 8자: 수직 스템 + 사선 가지, 같은 획 문법(stroke 2, round cap).
// 로컬 좌표 x∈[-2.5,2.5], y∈[-4.5,4.5] — 띠(r79~r93) 안에 stroke 여유(±1)까지 수납:
// 룬 radial 범위 86±5.5 = [80.5, 91.5] ⊂ (79.5, 92.25) = 두 링 획 안쪽 띠. 겹침 없음
// (인접 룬↔다이아 각도 22.5°, 각 반폭 ≈2.3°+3.0°).
const RUNE_PATHS = [
  'M-2 -4.5V4.5M-2 -1.5L2 -3.5M-2 1.5L2 -0.5', // ᚠ 풍요
  'M-2 4.5V-4.5L2 -1V4.5', // ᚢ 들소
  'M-1.5 -4.5V4.5M-1.5 -2.2L2 0L-1.5 2.2', // ᚦ 가시
  'M-2 -4.5V4.5M-2 -4L2 -2M-2 -1L2 1', // ᚨ 신탁
  'M-2 -4.5V4.5M-2 -4.5L2 -3L-2 -1L2 4.5', // ᚱ 여정
  'M2 -4.5L-2 0L2 4.5', // ᚲ 횃불
  'M-2 -4.5V4.5M-2 -4.5L2 -2.8L-2 -1', // ᚹ 기쁨
  'M-2.5 -4.5V4.5M2.5 -4.5V4.5M-2.5 -4.5L2.5 0M2.5 -4.5L-2.5 0', // ᛗ 사람
];
const RUNE_R = 86; // 룬 띠 중심 반지름
// 접선 방향 배치: rotate(θ, 중심) 후 위(-y)로 RUNE_R 이동 — 룬의 위가 항상 바깥(중심을 등지고 바로 섬)
const sealRunes = RUNE_PATHS.map((d, i) => {
  const deg = 22.5 + i * 45; // 방위(0·90·180·270°) 사이 45° 슬롯
  return `<g transform="rotate(${deg} 100 100) translate(100 ${100 - RUNE_R})"><path d="${d}"/></g>`;
}).join('');
// N/E/S/W — 룬 띠를 끊고 앉는 ✦ 마름모 (룬과 같은 반지름)
const sealDiamonds = [0, 90, 180, 270]
  .map((deg) => `<path transform="rotate(${deg} 100 100)" d="M100 ${100 - RUNE_R - 4.5}l4.5 4.5-4.5 4.5-4.5-4.5z"/>`)
  .join('');
---

<Base title="여행자의 쉼터" description="블로그와 글쓴이 소개, 연락처.">
  <!-- 공용 배너(작은 히어로): 여관의 문 앞 — 화롯불 온기는 앰버 베일 오버레이로만 -->
  <PageBanner
    slot="hero"
    height="tall"
    eyebrow="The Wayfarer's Rest"
    title="여행자의 쉼터"
    flavor="“먼 길을 오셨군. 난롯가에 앉으시게.”"
  >
    <div slot="overlay" class="hearth-veil" aria-hidden="true"></div>
  </PageBanner>

  <!-- 방랑자에 대하여 -->
  <section class="home-section" id="wanderer">
    <div class="section-head" data-animate>
      <div class="orn-line" data-orn="headpiece" aria-hidden="true"></div>
      <span class="eyebrow">The Wanderer</span>
      <h2>방랑자에 대하여</h2>
      <div class="orn-line tail" data-orn="tailpiece" aria-hidden="true"></div>
    </div>

    <div class="about-grid">
      <div class="essay" data-animate>
        <p class="lead">
          이 여관의 주인은 데이터의 길을 걷는 방랑자다. 낮에는 공학자 길드에서 파이썬과
          SQL로 데이터의 물길을 벼리고, 해가 기울면 수학자의 탑 계단을 오르며, 밤이
          깊으면 마법사의 도서관에서 타인의 생을 잠시 빌려 읽는다. 이따금 작가의
          집필실에 틀어박혀, 아직 이름 없는 세계의 첫 문장을 만지작거리기도 한다.
        </p>
        <p>
          한 우물을 깊이 파는 이들을 존경한다. 다만 이 발은 우물보다 길을 좋아했다. 열두
          장소 중 안개에 싸인 곳은 아직 열리지 않은 땅 — 첫 기록이 남는 순간 안개가
          걷히니, 억지로 걷어 내지 않고 천천히 지도를 그려 갈 생각이다. 안개는
          부끄러움이 아니라 예고편이므로.
        </p>
        <p>
          그러니 이곳의 기록은 완성된 지도가 아니라 걸으며 그린 초안에 가깝다. 틀린 길도
          지우지 않고 남겨 둔다. 언젠가 누군가에게는, 틀린 길의 기록이 가장 좋은 이정표가
          될 것이므로.
        </p>
        <p class="essay-sign"><span class="dia" aria-hidden="true">✦</span>교차로의 방랑자 씀</p>
      </div>

      <!-- 방랑자의 인장 — 나침반 문장 확대 + 룬 링 플레이트 -->
      <div class="seal-plate" data-animate>
        <span class="card-corner card-corner-tl" aria-hidden="true"></span>
        <span class="card-corner card-corner-tr" aria-hidden="true"></span>
        <span class="card-corner card-corner-bl" aria-hidden="true"></span>
        <span class="card-corner card-corner-br" aria-hidden="true"></span>
        <div class="seal-svg" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <!-- 룬 띠를 감싸는 바깥·안쪽 가는 링 -->
            <circle cx="100" cy="100" r="93" stroke-width="1.5"></circle>
            <circle cx="100" cy="100" r="79" stroke-width="1"></circle>
            <!-- 룬 링 — 방위 사이 45° 슬롯 8자 (frontmatter에서 배치 계산) -->
            <g stroke-width="2" set:html={sealRunes} />
            <!-- N/E/S/W 방위 다이아 — 룬 띠를 끊고 앉음 -->
            <g fill="currentColor" stroke="none" set:html={sealDiamonds} />
            <!-- 안쪽 링 -->
            <circle cx="100" cy="100" r="60" stroke-width="1"></circle>
            <!-- 나침반 컴퍼스 로즈 (브랜드 문장 확대) -->
            <g transform="translate(35.2 35.2) scale(2.7)" stroke-width="1.2">
              <path d="M24 5 L27.6 20.4 L43 24 L27.6 27.6 L24 43 L20.4 27.6 L5 24 L20.4 20.4 Z"></path>
              <circle cx="33" cy="15" r="1.3" fill="currentColor" stroke="none"></circle>
              <circle cx="33" cy="33" r="1.3" fill="currentColor" stroke="none"></circle>
              <circle cx="15" cy="33" r="1.3" fill="currentColor" stroke="none"></circle>
              <circle cx="15" cy="15" r="1.3" fill="currentColor" stroke="none"></circle>
            </g>
            <circle cx="100" cy="100" r="3" fill="currentColor" stroke="none"></circle>
          </svg>
        </div>
        <div class="seal-cap">Sigillum Viatoris</div>
        <p class="seal-note">방랑자의 인장.<br />이름은 길에 두고 왔으니, 인장으로 대신한다.</p>
      </div>
    </div>
  </section>

  <div class="orn" aria-hidden="true">✦&nbsp;&nbsp;✦&nbsp;&nbsp;✦</div>

  <!-- 여정의 기록 — 칭호의 방 (12장소 전부, places.ts 순서) -->
  <section class="home-section" id="titles">
    <div class="section-head" data-animate>
      <div class="orn-line" data-orn="headpiece" aria-hidden="true"></div>
      <span class="eyebrow">Hall of Titles</span>
      <h2>여정의 기록 — 칭호의 방</h2>
      <div class="orn-line tail" data-orn="tailpiece" aria-hidden="true"></div>
    </div>

    <div class="titles-grid" data-stagger>
      {
        PLACES.map((place) => {
          const count = countBy.get(place.slug) ?? 0;
          const rank = rankFor(place, count);
          return rank ? (
            <div class="title-card tinted" data-animate style={tintStyle(place)}>
              <span class="card-corner card-corner-tl" aria-hidden="true" />
              <span class="card-corner card-corner-tr" aria-hidden="true" />
              <span class="card-corner card-corner-bl" aria-hidden="true" />
              <span class="card-corner card-corner-br" aria-hidden="true" />
              <span class="tc-icon" aria-hidden="true">
                <Emblem id={place.slug} size={30} />
              </span>
              <div class="tc-name">{place.ko}</div>
              <div class="tc-en">{place.en}</div>
              <div class="tc-rank">
                <i class="dia" aria-hidden="true">✦</i>
                {rank}
              </div>
              <div class="tc-meta">기록 {count}편</div>
            </div>
          ) : (
            <div class="title-card fog" data-animate>
              <span class="tc-icon" aria-hidden="true">
                <Emblem id={place.slug} size={30} />
              </span>
              <div class="tc-name">{place.ko}</div>
              <div class="tc-en">{place.en}</div>
              <div class="tc-rank">안개에 싸임</div>
              <div class="tc-meta">아직 열리지 않았다</div>
            </div>
          );
        })
      }
    </div>

    <p class="titles-note" data-animate>
      {
        openCount > 0
          ? `열두 장소 중 ${KO_COUNT[openCount]} 곳의 안개가 걷혔다`
          : '열두 장소 모두 아직 안개에 싸여 있다'
      }<span class="dia" aria-hidden="true">✦</span>칭호는 기록이 쌓일수록 깊어진다
    </p>
  </section>

  <div class="orn" aria-hidden="true">✦&nbsp;&nbsp;✦&nbsp;&nbsp;✦</div>

  <!-- 이 교차로에 대하여 — 취지 (copy-deck §7) -->
  <section class="home-section" id="crossroads">
    <div class="section-head" data-animate>
      <div class="orn-line" data-orn="headpiece" aria-hidden="true"></div>
      <span class="eyebrow">About the Crossroads</span>
      <h2>이 교차로에 대하여</h2>
      <div class="orn-line tail" data-orn="tailpiece" aria-hidden="true"></div>
    </div>

    <div class="cross-list" data-animate>
      {
        CREDO.map(({ lead, rest }) => (
          <div class="cross-row">
            <span class="cr-dia" aria-hidden="true">✦</span>
            <span class="cr-copy"><strong>{lead}</strong> — {rest}</span>
          </div>
        ))
      }
    </div>
  </section>

  <div class="orn" aria-hidden="true">✦&nbsp;&nbsp;✦&nbsp;&nbsp;✦</div>

  <!-- 전서구를 보내려면 -->
  <section class="home-section" id="contact">
    <div class="section-head" data-animate>
      <div class="orn-line" data-orn="headpiece" aria-hidden="true"></div>
      <span class="eyebrow">Send a Pigeon</span>
      <h2>전서구를 보내려면</h2>
      <div class="orn-line tail" data-orn="tailpiece" aria-hidden="true"></div>
    </div>

    <div class="contact-wrap" data-animate>
      <p class="contact-lead">
        여관 주인에게 말을 전하고 싶다면, 세 갈래 길 중 하나로 전서구를 날리면 된다.<br />
        작업장을 구경하거나, 새 기록의 소식을 받아 보거나, 봉인된 서신을 보내거나.
      </p>
      <div class="contact-btns">
        <a class="pigeon-btn" href="https://github.com/Liberiter" aria-label="GitHub 프로필">
          <svg viewBox="0 0 48 48" aria-hidden="true"><circle cx="14" cy="10" r="4"></circle><circle cx="14" cy="38" r="4"></circle><circle cx="34" cy="14" r="4"></circle><path d="M14 14v20"></path><path d="M34 18a12 12 0 0 1-12 12h-4"></path></svg>
          GitHub
        </a>
        <a class="pigeon-btn" href="/rss.xml" aria-label="RSS 구독">
          <svg viewBox="0 0 48 48" aria-hidden="true"><circle cx="12" cy="36" r="2.6" fill="currentColor" stroke="none"></circle><path d="M9 22a17 17 0 0 1 17 17"></path><path d="M9 10a29 29 0 0 1 29 29"></path></svg>
          전서구 (RSS)
        </a>
        <a class="pigeon-btn" href="mailto:rublin322@gmail.com" id="mail-btn" aria-label="이메일 주소 복사">
          <svg viewBox="0 0 48 48" aria-hidden="true"><path d="M7 12h34v24H7z"></path><path d="M7 13l17 13 17-13"></path></svg>
          봉인 서신 (Email)
        </a>
      </div>
      <p class="copy-toast" id="copy-toast" role="status" aria-live="polite">
        주소를 필사해 두었다 <span class="dia" aria-hidden="true">✦</span>
      </p>
      <p class="contact-note">답신은 바람의 사정에 따라 늦을 수 있다.</p>
    </div>
  </section>
</Base>

<script>
  import { initScrollAnimations } from '../scripts/scroll-animations';
  initScrollAnimations();

  // ── 봉인 서신 — 메일 앱이 없는 환경 배려: 클릭 시 주소를 클립보드에 필사 ──
  // href는 mailto 유지(우클릭·메일 앱 사용자 배려), 기본 동작만 가로채 복사한다.
  // clipboard 실패 시(비보안 컨텍스트 등)에는 mailto 기본 동작으로 폴백.
  const mailBtn = document.getElementById('mail-btn');
  const copyToast = document.getElementById('copy-toast');
  let toastTimer: ReturnType<typeof setTimeout> | undefined;

  mailBtn?.addEventListener('click', (e) => {
    if (!navigator.clipboard?.writeText) return; // 폴백: mailto 그대로
    e.preventDefault();
    navigator.clipboard.writeText('rublin322@gmail.com').then(
      () => {
        if (!copyToast) return;
        copyToast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => {
          copyToast.classList.remove('show');
        }, 2500);
      },
      () => {
        // 복사 실패 — 메일 앱으로 폴백
        window.location.href = 'mailto:rublin322@gmail.com';
      }
    );
  });
</script>

<style>
  /* ══ 화롯불 온기 반 톤 ↑ — 이 페이지에서만 토큰 오버라이드 ══
     (docs/mockups/rest.html — 수채 워시·앰비언트에 앰버 기운.
     body에 얹어 :root 토큰을 이 페이지에서만 덮는다. 테마 3단 오버라이드 정합.) */
  :global(body) {
    --wash: linear-gradient(160deg, color-mix(in srgb, #c0655b 5%, var(--card)) 0%, var(--card) 46%, color-mix(in srgb, var(--gold-dim) 5%, var(--card)) 100%);
    --wash-hover: linear-gradient(160deg, color-mix(in srgb, #c0655b 7%, var(--card)) 0%, var(--card) 46%, color-mix(in srgb, var(--gold-dim) 7%, var(--card)) 100%);
    --ambient-bg: radial-gradient(120% 85% at 50% -12%, color-mix(in srgb, #c07445 5%, var(--bg)) 0%, var(--bg) 62%);
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light']) body) {
      --wash: linear-gradient(155deg, color-mix(in srgb, var(--viridian) 8%, var(--card)) 0%, var(--card) 46%, color-mix(in srgb, var(--gold) 7%, var(--card)) 100%);
      --wash-hover: linear-gradient(155deg, color-mix(in srgb, var(--viridian) 11%, var(--card-hover)) 0%, var(--card-hover) 46%, color-mix(in srgb, var(--gold) 9%, var(--card-hover)) 100%);
      --ambient-bg: radial-gradient(120% 85% at 50% -12%, color-mix(in srgb, var(--gold) 5%, var(--bg)) 0%, var(--bg) 62%);
    }
  }
  :global(:root[data-theme='dark'] body) {
    --wash: linear-gradient(155deg, color-mix(in srgb, var(--viridian) 8%, var(--card)) 0%, var(--card) 46%, color-mix(in srgb, var(--gold) 7%, var(--card)) 100%);
    --wash-hover: linear-gradient(155deg, color-mix(in srgb, var(--viridian) 11%, var(--card-hover)) 0%, var(--card-hover) 46%, color-mix(in srgb, var(--gold) 9%, var(--card-hover)) 100%);
    --ambient-bg: radial-gradient(120% 85% at 50% -12%, color-mix(in srgb, var(--gold) 5%, var(--bg)) 0%, var(--bg) 62%);
  }

  /* ══ 배너 위 화롯불 온기 — 옅은 앰버 베일 오버레이 (PageBanner overlay 슬롯) ══
     기본 그라데이션은 공용 배너(여명/숲) 그대로, 온기 반 톤만 이 베일이 얹는다. */
  .hearth-veil {
    position: absolute;
    inset: 0;
    z-index: 2; /* 전역 파티클 캔버스(z1) 위, 페이드(z4)·콘텐츠(z5) 아래 */
    pointer-events: none;
    background: radial-gradient(85% 75% at 50% 102%, rgba(224, 150, 70, 0.22), transparent 66%);
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .hearth-veil {
      background: radial-gradient(75% 65% at 50% 104%, rgba(226, 152, 58, 0.14), transparent 64%);
    }
  }
  :global(:root[data-theme='dark']) .hearth-veil {
    background: radial-gradient(75% 65% at 50% 104%, rgba(226, 152, 58, 0.14), transparent 64%);
  }

  /* ══ 방랑자 소개 — 에세이 + 방랑자의 인장 ══ */
  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2.2rem;
    align-items: start;
    max-width: 960px;
    margin: 0 auto;
  }
  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
  .essay p {
    font-family: var(--serif);
    font-size: 15.5px;
    line-height: 2.05;
    color: var(--ink);
    margin: 0 0 1.15em;
    text-wrap: pretty;
  }
  /* 드롭캡 — 에세이 첫 문단 (WORLDBOOK §3.3) */
  .essay p.lead::first-letter {
    float: left;
    font-family: var(--serif);
    font-weight: 700;
