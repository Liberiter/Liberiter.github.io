  /* ── 수학 박스 — 정리/보조정리/정의/증명 (remark-boxes, WORLDBOOK §3.3 탑 전용) ──
     :::theorem{title="..."} → .math-box.math-box--theorem + .math-box-label */
  .record :global(.math-box) {
    margin: 1.7em 0;
