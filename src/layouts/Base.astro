---
// 모든 페이지의 바탕 (v4 셸). 세계관 용어는 화면에만, 메타데이터는 평범하게 (WORLDBOOK §1.2).
// UI 문구는 docs/copy-deck.md §1이 단일 원천.
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/700.css';
import '@fontsource/gowun-batang/400.css';
import '@fontsource/gowun-batang/700.css';
import '@fontsource/nanum-gothic-coding/400.css';
import '@fontsource/nanum-gothic-coding/700.css';
import 'pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css';
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import spriteRaw from '../../assets/emblems.svg?raw';
import AmbientParticles from '../components/AmbientParticles.astro';
import Emblem from '../components/Emblem.astro';
import FolioFrame from '../components/FolioFrame.astro';
import MobileMenu from '../components/MobileMenu.astro';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string; // 루트 상대 경로 — 지정하면 관례 URL 대신 사용
}
const SITE = "The Wanderer's Crossroads";
const {
  title,
  description = '방랑자의 기록이 쌓이는 교차로 — 기술, 수학, 책, 그리고 이야기.',
  ogImage,
} = Astro.props;
const pageTitle = title ? `${title} — ${SITE}` : SITE;

// 내비 (copy-deck §1)
const NAV = [
  { href: '/', label: '교차로' },
  { href: '/places/', label: '열두 장소' },
  { href: '/records/', label: '서고' },
  { href: '/chronicles/', label: '연대기' },
  { href: '/journal/', label: '방랑자의 일지' },
  { href: '/rest/', label: '여행자의 쉼터' },
];
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href);

// ── OG 이미지 관례 URL — 엔드포인트 src/pages/og/[...slug].png.ts 와 반드시 일치 ──
// 규칙: 홈·대표 정적 페이지는 OG_STATIC 매핑, 기록/일지 상세는 /og/<경로>.png,
//       그 외 모든 페이지(태그·장소 상세·404 등)는 /og/default.png 폴백.
const OG_STATIC: Record<string, string> = {
  '': 'index',
  records: 'records',
  places: 'places',
  chronicles: 'chronicles',
  journal: 'journal',
  rest: 'rest',
};
const ogKey = path.replace(/^\/+|\/+$/g, ''); // '/records/foo/' → 'records/foo'
let ogPath = '/og/default.png';
if (Object.hasOwn(OG_STATIC, ogKey)) ogPath = `/og/${OG_STATIC[ogKey]}.png`;
else if (/^(records|journal)\/.+/.test(ogKey)) ogPath = `/og/${ogKey}.png`;
const ogImageURL = new URL(ogImage ?? ogPath, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE} href={new URL('rss.xml', Astro.site)} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageURL} />
    <script is:inline>
      // 테마를 페인트 전에 확정 (깜빡임 방지) — 항상 data-theme를 찍어
      // 헤더 적응/파티클이 확실한 테마 값을 읽을 수 있게 한다
      (function () {
        // ?theme=dark|light 로 강제 가능 (미리보기·공유용)
        const forced = new URLSearchParams(location.search).get('theme');
        const saved = localStorage.getItem('theme');
        const theme =
          forced === 'dark' || forced === 'light'
            ? forced
            : saved === 'dark' || saved === 'light'
              ? saved
              : matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <Fragment set:html={spriteRaw} />

    <a class="skip-link" href="#main">본문으로 건너가기</a>

    <FolioFrame />
    <AmbientParticles />

    <header class="site-header" id="site-header">
      <div class="hd-in">
        <a class="brand" href="/">
          <Emblem id="crossroads" size={21} />
          <span class="en">The Wanderer's Crossroads</span>
          <span class="en en-short">Crossroads</span>
        </a>
        <nav class="primary" aria-label="사이트 내비게이션">
          {
            NAV.map((item) => (
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <button class="ask-guide" type="button" id="search-trigger" aria-label="검색">
          <span class="dia" aria-hidden="true">✦</span>길잡이에게 묻기
        </button>
        <div class="theme-toggle" role="group" aria-label="테마 전환">
          <button type="button" data-set-theme="light" aria-pressed="false" title="동이 튼다" aria-label="라이트 테마로 전환">
            <!-- 이정표 -->
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18M12 21h4M5 7h11l3 2-3 2H5zM19 13H9l-3 2 3 2h10z"></path></svg>
            여명
          </button>
          <button type="button" data-set-theme="dark" aria-pressed="false" title="모닥불 곁으로" aria-label="다크 테마로 전환">
            <!-- 등불 -->
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 4h6M12 4v2M8 6h8l1 10a5 5 0 0 1-10 0zM12 10a2.5 2.5 0 0 1 2 3 2 2 0 0 1-4 0 2.5 2.5 0 0 1 2-3zM10 21h4"></path></svg>
            모닥불
          </button>
        </div>
        <button
          type="button"
          class="menu-trigger"
          id="menu-trigger"
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="dia" aria-hidden="true">✦</span>메뉴
        </button>
      </div>
    </header>

    <slot name="hero" />

    <main id="main" class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="orn-line tail-orn" data-orn="tailpiece" aria-hidden="true"></div>
      <div class="links">
        <a href="/rss.xml">전서구 (RSS)</a>
        <a href="https://github.com/Liberiter">GitHub</a>
      </div>
      <p class="colophon">© {new Date().getFullYear()} The Wanderer — 모든 기록은 이 길 위에서 쓰였다</p>
    </footer>

    <SearchModal />
    <MobileMenu nav={NAV} path={path} />

    <script>
      import { initOrnaments } from '../scripts/ornaments';

      // ── 절차 생성 오너먼트 (폴리오 프레임 코너 + 헤드피스/테일피스) ──
      initOrnaments();

      // ── 테마: 여명 ↔ 모닥불 (헤더 토글 + 모바일 메뉴 토글 — [data-set-theme] 공용) ──
      const root = document.documentElement;
      const themeBtns = Array.from(
        document.querySelectorAll<HTMLButtonElement>('[data-set-theme]')
      );

      // head 인라인 스크립트가 항상 data-theme를 확정해 둔다
      const effectiveTheme = () => (root.dataset.theme === 'dark' ? 'dark' : 'light');

      function syncToggle() {
        const t = effectiveTheme();
        for (const b of themeBtns) b.setAttribute('aria-pressed', String(b.dataset.setTheme === t));
      }
      function setTheme(t: 'light' | 'dark') {
        root.dataset.theme = t;
        localStorage.setItem('theme', t);
        syncToggle();
        // 파티클 등 테마 연동 요소에 알림 (legacy 호환 이벤트)
        document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: t } }));
      }
      for (const b of themeBtns) {
        b.addEventListener('click', () => setTheme(b.dataset.setTheme === 'dark' ? 'dark' : 'light'));
      }
      syncToggle();

      // ── 헤더: 연속 스크롤 적응형 프로스트 글라스 ──
      // --hd-p(0~1)를 스크롤 진행도로 갱신 — 범위는 [data-hd-range] 요소
      // (홈=히어로, 서브페이지=배너)가 있으면 그 높이, 없으면 뷰포트 높이.
      // smoothstep으로 초반은 투명을 오래 유지, 끝에서 완만히 수렴.
      const headerEl = document.getElementById('site-header');
      const rangeEl = document.querySelector<HTMLElement>('[data-hd-range]');
      let hdPending = false;

      function updateHeader() {
        if (!headerEl) return;
        const y = window.scrollY || 0;
        const base = rangeEl ? rangeEl.offsetHeight : window.innerHeight;
        const range = Math.max(240, base - 60);
        let p = Math.min(1, Math.max(0, y / range));
        p = p * p * (3 - 2 * p); // smoothstep
        headerEl.style.setProperty('--hd-p', p.toFixed(4));
      }
      function queueHeader() {
        if (hdPending) return;
        hdPending = true;
        requestAnimationFrame(() => {
          hdPending = false;
          updateHeader();
        });
      }
      window.addEventListener('scroll', queueHeader, { passive: true });
      window.addEventListener('resize', queueHeader);
      updateHeader();

      // ── 길잡이에게 묻기 — 검색 트리거 (SearchModal이 open-search를 수신) ──
      document.getElementById('search-trigger')?.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('open-search'));
      });
    </script>
  </body>
</html>
